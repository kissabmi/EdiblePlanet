; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited via script.

[application]

config/name="Edible Planet: Cosmic Feast"
config/description="Cooperative 2D game — two players control one edible planet!"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

InputManager="*res://scripts/autoload/input_manager.gd"
ScoreManager="*res://scripts/autoload/score_manager.gd"
WaveManager="*res://scripts/autoload/wave_manager.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/vsync/vsync_mode=1

